#!/usr/bin/env sh
BASEDIR=$(dirname "$0")
if [ -z "$BASEDIR" ] ; then
  BASEDIR="."
fi
BASEDIR=$(cd "$BASEDIR" && pwd)
if [ -n "$JAVA_HOME" ]; then
  JAVA_CMD="$JAVA_HOME/bin/java"
else
  JAVA_CMD=java
fi
exec "$JAVA_CMD" -cp "$BASEDIR/.mvn/wrapper/maven-wrapper.jar" org.apache.maven.wrapper.MavenWrapperMain "$@"
