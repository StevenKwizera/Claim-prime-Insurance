{
  "name": "prime-insurance-claims-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "backend": "powershell -ExecutionPolicy Bypass -File backend/start-backend.ps1",
    "db:setup": "mvn -f backend/pom.xml -q test",
    "evidence:fetch": "powershell -ExecutionPolicy Bypass -File scripts/fetch-evidence-media.ps1",
    "db:sync-seed": "cd frontend && npx --yes tsx ../scripts/sync-seed-db.ts",
    "dev": "vite --config frontend/vite.config.ts",
    "build": "tsc -b frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.59.0",
    "axios": "^1.7.7",
    "chart.js": "^4.4.6",
    "clsx": "^2.1.1",
    "formik": "^2.4.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.453.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.9",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.0",
    "socket.io-client": "^4.8.0",
    "yup": "^1.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
